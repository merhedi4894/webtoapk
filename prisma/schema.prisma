generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AppBuild {
  id              String   @id @default(cuid())
  appName         String
  packageName     String
  websiteUrl      String
  backgroundColor String   @default("#FFFFFF")
  splashText      String   @default("")
  splashDuration  Int      @default(3000)
  iconPath        String?
  orientation     String   @default("unspecified")
  themeMode       String   @default("light")
  enableNavbar    Boolean  @default(true)
  enablePullRefresh Boolean @default(false)
  enableFileAccess Boolean  @default(false)
  enableCamera    Boolean  @default(false)
  enableLocation  Boolean  @default(false)
  enableStorage   Boolean  @default(false)
  enableNotifications Boolean @default(false)
  customUserAgent String?
  status          String   @default("pending")
  apkPath         String?
  buildLog        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
